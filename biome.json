{
  "files": {
    "includes": ["**", "!!**/convex/_generated"]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn",
        "useHookAtTopLevel": "error",
        "useExhaustiveDependencies": "warn"
      },
      "suspicious": {
        "noArrayIndexKey": "warn"
      },
      "performance": {
        "noAccumulatingSpread": "off"
      },
      "nursery": {
        "useSortedClasses": {
          "level": "warn",
          "fix": "safe"
        }
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": false
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on"
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["convex/functions/vesselOrchestrator/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "domain/vesselOrchestration/updateVesselTrips/**",
                      "domain/vesselOrchestration/updateTimeline/**",
                      "domain/vesselOrchestration/updateVesselPredictions/**"
                    ],
                    "message": "Import vesselOrchestration peers via their folder entry (index.ts), not deep leaf paths."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["convex/functions/vesselTrips/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "domain/vesselOrchestration/updateVesselTrips/**",
                      "domain/vesselOrchestration/updateTimeline/**",
                      "domain/vesselOrchestration/updateVesselPredictions/**"
                    ],
                    "message": "Import vesselOrchestration peers via their folder entry (index.ts), not deep leaf paths."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "convex/domain/vesselOrchestration/updateVesselTrips/**/*.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["domain/vesselOrchestration/updateTimeline/**"],
                    "message": "Handshake types live in domain/vesselOrchestration/shared/tickHandshake; do not import updateTimeline from updateVesselTrips."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
